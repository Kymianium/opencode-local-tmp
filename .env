# Zona horaria para los contenedores
TZ=Europe/Madrid

# Puerto y contraseña para acceder a OpenCode Server
OPENCODE_PORT=4096
OPENCODE_SERVER_PASSWORD=opencode_secure_pass

# Etiqueta del modelo GLM 5.2 en Ollama (por ejemplo, 'glm-5.2' o 'glm-5.2:cloud')
OLLAMA_MODEL_TAG=glm-5.2

# Puerto para acceder a la API de Ollama
OLLAMA_PORT=11434
